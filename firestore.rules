rules_version = '2';

// ─── HerNest Firestore Security Rules ────────────────────────────
// Source of truth for access control. Created for migration Steps 1–2.
//
// Model: a household's id IS the owner's uid. Every user has full access to
// their OWN namespace (unchanged from before). Household MEMBERS additionally
// get access to a fixed set of SHARED collections under the owner's namespace,
// plus the household doc, member roster, and append-only event log.
//
// Membership is anchored to users/{uid}/data/household_link, which is written
// ONLY by the trusted /api/invite/accept admin endpoint — so a client cannot
// grant itself membership in someone else's household.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Collections under users/{ownerUid}/data that are shared with the whole
    // household. KEEP IN SYNC with HOUSEHOLD_COLLECTIONS in src/core/identity.ts.
    // (thrive + cleo_memory* are intentionally NOT here — they stay personal
    // until per-member consent lands in migration Step 5.)
    function householdShared() {
      return [
        'budget', 'budget_v2', 'tasks', 'calendar', 'trips',
        'school', 'circle', 'household_insights', 'household_graph'
      ];
    }

    // True if the signed-in user belongs to household {ownerUid}: either they
    // ARE the owner, or the trusted invite flow wrote them a household_link
    // pointing at it. (get/exists in rules are privileged — they bypass rules.)
    function isMember(ownerUid) {
      return isSignedIn() && (
        request.auth.uid == ownerUid ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/data/household_link) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)/data/household_link).data.primaryUid == ownerUid
        )
      );
    }

    // ── User namespace ───────────────────────────────────────────
    // Full access to your OWN namespace EXCEPT data/ (handled explicitly
    // below so household_link can be locked down — see security note).
    match /users/{ownerUid}/{col}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == ownerUid && col != 'data';
    }

    // data/: owner reads everything; owner writes everything EXCEPT
    // household_link. SECURITY: household_link is what isMember() trusts —
    // if clients could write their own, anyone could forge a link pointing
    // at any household and read its shared data (found by the rules test
    // suite, 2026-07-10). Only the admin SDK (/api/invite/accept and
    // /api/household) may write it — admin bypasses rules.
    // Household members additionally read/write the shared subset.
    match /users/{ownerUid}/data/{col} {
      allow read: if (isSignedIn() && request.auth.uid == ownerUid)
                  || (householdShared().hasAny([col]) && isMember(ownerUid));
      allow write: if (isSignedIn() && request.auth.uid == ownerUid && col != 'household_link')
                   || (householdShared().hasAny([col]) && isMember(ownerUid));
    }

    // ── Households ───────────────────────────────────────────────
    match /households/{hid} {
      allow read: if isMember(hid);
      // You can only create/update YOUR OWN household doc (hid == your uid).
      allow create, update: if isSignedIn() && request.auth.uid == hid;
      allow delete: if false;

      // Member roster — each user writes only their OWN membership, and only
      // into a household they legitimately belong to (owner, or invited).
      match /members/{memberUid} {
        allow read: if isMember(hid);
        allow create, update: if request.auth.uid == memberUid && isMember(hid);
        allow delete: if request.auth.uid == memberUid || request.auth.uid == hid;
      }

      // Shared, append-only household event log (migration Step 2).
      match /events/{eventId} {
        allow read: if isMember(hid);
        allow create: if isMember(hid)
                      && request.resource.data.actorUserId == request.auth.uid;
        allow update, delete: if false; // append-only
      }
    }

    // ── Invites ──────────────────────────────────────────────────
    // Read/written only by the admin SDK in /api/invite/*. No client access.
    match /invites/{token} {
      allow read, write: if false;
    }

    // Everything else is denied by Firestore's default (no matching allow).
  }
}
