# ── Client (exposed in browser bundle — safe to expose) ────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Server-only (Vercel env vars — NEVER commit real values) ───────
ANTHROPIC_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AES-256 key for stored calendar credentials (64 hex chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# Comma-separated origins allowed to call /api endpoints
ALLOWED_ORIGINS=https://hernest-v2.vercel.app,http://localhost:5173

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (partner invites)
RESEND_API_KEY=

# Stripe (Pro subscriptions) — leave blank to fall back to waitlist mode
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
APP_URL=https://hernest-v2.vercel.app

# Plaid (bank feed) — leave blank and the bank connector shows "not set up".
# PLAID_ENV: sandbox | development | production
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Overnight cron auth — set any random string; Vercel sends it as a Bearer
# token to /api/cron so the endpoint rejects anyone else.
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
CRON_SECRET=

# Oura Ring (sleep/readiness/activity → Thrive). Register an app at
# cloud.ouraring.com/oauth/applications, redirect URI:
#   https://hernest-v2.vercel.app/api/auth/oura/callback
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
